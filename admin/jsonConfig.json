{
	"i18n": true,
	"type": "tabs",
	"iconPosition": "top",
	"items": {
		"mainSettings": {
			"type": "panel",
			"label": "Haupteinstellungen",
			"icon": "data:image/svg+xml;base64,",
			"items": {
				"headerConnection": {
					"type": "header",
					"text": "Verbindungseinstellungen",
					"size": 4,
					"sm": 12
				},
				"host": {
					"type": "text",
					"label": "IP-Adresse (Host)",
					"sm": 12,
					"md": 4
				},
				"port": {
					"type": "number",
					"label": "Port",
					"sm": 12,
					"md": 4
				},
				"interval": {
					"type": "number",
					"label": "Abfrageintervall (Sekunden)",
					"min": 10,
					"sm": 12,
					"md": 4
				},

				"abstandRegelung": {
					"type": "divider"
				},

				"regelung_aktiv": {
					"type": "select",
					"label": "Status der automatischen Regelung",
					"options": [
						{ "label": "Aktiv", "value": true },
						{ "label": "Inaktiv", "value": false }
					],
					"sm": 12,
					"md": 12
				},

				"headerHeating": {
					"type": "header",
					"text": "Vorgabewerte Heizen",
					"size": 4,
					"sm": 12
				},
				"fusspunkt": {
					"type": "number",
					"label": "Fußpunkt (°C)",
					"sm": 12,
					"md": 4,
					"disabled": "data.regelung_aktiv === false"
				},
				"endpunkt": {
					"type": "number",
					"label": "Endpunkt (°C)",
					"sm": 12,
					"md": 4,
					"disabled": "data.regelung_aktiv === false"
				},
				"sync_return_temperature_hysteresis": {
					"type": "number",
					"label": "Heizen Hysterese (K)",
					"sm": 12,
					"md": 4,
					"disabled": "data.regelung_aktiv === false"
				},
				"sync_heating_system_circ_pump_voltage_minimal_heating": {
					"type": "number",
					"label": "HUP Min (V)",
					"sm": 12,
					"md": 6,
					"disabled": "data.regelung_aktiv === false"
				},
				"sync_heating_system_circ_pump_voltage_nominal_heating": {
					"type": "number",
					"label": "HUP Nom (V)",
					"sm": 12,
					"md": 6,
					"disabled": "data.regelung_aktiv === false"
				},
				"Heating_after_warmwater": {
					"type": "checkbox",
					"label": "Heizen nach Warmwasser",
					"sm": 12,
					"md": 12,
					"disabled": "data.regelung_aktiv === false"
				},

				"headerWater": {
					"type": "header",
					"text": "Vorgabewerte Warmwasser",
					"size": 4,
					"sm": 12
				},
				"sync_warmwater_target_temperature": {
					"type": "number",
					"label": "WW Soll (°C)",
					"sm": 12,
					"md": 6,
					"disabled": "data.regelung_aktiv === false"
				},
				"sync_hotwater_temperature_hysteresis": {
					"type": "number",
					"label": "WW Hysterese (K)",
					"sm": 12,
					"md": 6,
					"disabled": "data.regelung_aktiv === false"
				},
				"sync_heating_system_circ_pump_voltage_minimal_water": {
					"type": "number",
					"label": "HUP Min (V)",
					"sm": 12,
					"md": 6,
					"disabled": "data.regelung_aktiv === false"
				},
				"sync_heating_system_circ_pump_voltage_nominal_water": {
					"type": "number",
					"label": "HUP Nom (V)",
					"sm": 12,
					"md": 6,
					"disabled": "data.regelung_aktiv === false"
				},

				"headerZip": {
					"type": "header",
					"text": "Vorgabewerte Zirkulationspumpe",
					"size": 4,
					"sm": 12
				},
				"zip_aktiv": {
					"type": "number",
					"label": "ZIP Dauer an (s)",
					"sm": 12,
					"md": 4,
					"disabled": "data.regelung_aktiv === false"
				},
				"zip_last_run_min": {
					"type": "number",
					"label": "ZIP Dauer aus (s)",
					"sm": 12,
					"md": 4,
					"disabled": "data.regelung_aktiv === false"
				},
				"zip_aktiv_ww": {
					"type": "number",
					"label": "ZIP Dauer bei Warmwassererzeugung (s)",
					"sm": 12,
					"md": 4,
					"disabled": "data.regelung_aktiv === false"
				}
			}
		}
	}
}
