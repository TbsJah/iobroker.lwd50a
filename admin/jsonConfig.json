					"type": "number",
					"label": "WW Soll (°C)",
					"sm": 12,
					"md": 6,
					"disabled": "data.regelung_aktiv === false"
				},
				"sync_hotwater_temperature_hysteresis": {
					"type": "number",
					"label": "WW Hysterese (K)",
					"sm": 12,
					"md": 6,
					"disabled": "data.regelung_aktiv === false"
				},
				"sync_heating_system_circ_pump_voltage_minimal_water": {
					"type": "number",
					"label": "HUP Min (V)",
					"sm": 12,
					"md": 6,
					"disabled": "data.regelung_aktiv === false"
				},
				"sync_heating_system_circ_pump_voltage_nominal_water": {
					"type": "number",
					"label": "HUP Nom (V)",
					"sm": 12,
					"md": 6,
					"disabled": "data.regelung_aktiv === false"
				},
