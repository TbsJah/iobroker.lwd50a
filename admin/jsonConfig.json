				"zip_aktiv_ww": {
					"type": "number",
					"label": "ZIP Dauer bei Warmwassererzeugung (s)",
					"sm": 12,
					"md": 4,
					"disabled": "data.regelung_aktiv === false"
				}
			}
		},
		"notifications": {
			"type": "panel",
			"label": "Benachrichtigungen",
