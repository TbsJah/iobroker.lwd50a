{
	"i18n": true,
	"type": "tabs",
	"iconPosition": "top",
	"items": {
		"mainSettings": {
			"type": "panel",
			"label": "Haupteinstellungen",
			"icon": "data:image/svg+xml;base64,",
			"items": {
				"headerConnection": { "type": "header", "text": "Verbindungseinstellungen", "size": 4, "sm": 12 },
				"host": { "type": "text", "label": "IP-Adresse (Host)", "sm": 12, "md": 4 },
				"port": { "type": "number", "label": "Port", "sm": 12, "md": 4 },
				"interval": { "type": "number", "label": "Abfrageintervall (Sekunden)", "min": 10, "sm": 12, "md": 4 },
				"abstandRegelung": { "type": "divider" },
				"regelung_aktiv": {
					"type": "select",
					"label": "Status der automatischen Regelung",
					"options": [
						{ "label": "Aktiv", "value": true },
						{ "label": "Inaktiv", "value": false }
					],
					"sm": 12,
					"md": 12
				},
				"headerHeating": { "type": "header", "text": "Vorgabewerte Heizen", "size": 4, "sm": 12 },
				"fusspunkt": {
					"type": "number",
					"label": "Fußpunkt (°C)",
					"sm": 12,
					"md": 4,
					"disabled": "data.regelung_aktiv === false"
				},
				"endpunkt": {
					"type": "number",
					"label": "Endpunkt (°C)",
					"sm": 12,
					"md": 4,
					"disabled": "data.regelung_aktiv === false"
				},
				"sync_return_temperature_hysteresis": {
					"type": "number",
					"label": "Heizen Hysterese (K)",
					"sm": 12,
					"md": 4,
					"disabled": "data.regelung_aktiv === false"
				},
				"sync_heating_system_circ_pump_voltage_minimal_heating": {
					"type": "number",
					"label": "HUP Min (V)",
					"sm": 12,
					"md": 6,
					"disabled": "data.regelung_aktiv === false"
				},
				"sync_heating_system_circ_pump_voltage_nominal_heating": {
					"type": "number",
					"label": "HUP Nom (V)",
					"sm": 12,
					"md": 6,
					"disabled": "data.regelung_aktiv === false"
				},
				"Heating_after_warmwater": {
					"type": "checkbox",
					"label": "Heizen nach Warmwasser",
					"sm": 12,
					"md": 12,
					"disabled": "data.regelung_aktiv === false"
				},
				"headerWater": { "type": "header", "text": "Vorgabewerte Warmwasser", "size": 4, "sm": 12 },
				"sync_warmwater_target_temperature": {
					"type": "number",
					"label": "WW Soll (°C)",
					"sm": 12,
					"md": 6,
					"disabled": "data.regelung_aktiv === false"
				},
				"sync_hotwater_temperature_hysteresis": {
					"type": "number",
					"label": "WW Hysterese (K)",
					"sm": 12,
					"md": 6,
					"disabled": "data.regelung_aktiv === false"
				},
				"sync_heating_system_circ_pump_voltage_minimal_water": {
					"type": "number",
					"label": "HUP Min (V)",
					"sm": 12,
					"md": 6,
					"disabled": "data.regelung_aktiv === false"
				},
				"sync_heating_system_circ_pump_voltage_nominal_water": {
					"type": "number",
					"label": "HUP Nom (V)",
					"sm": 12,
					"md": 6,
					"disabled": "data.regelung_aktiv === false"
				},
				"headerZip": { "type": "header", "text": "Vorgabewerte Zirkulationspumpe", "size": 4, "sm": 12 },
				"zip_aktiv": {
					"type": "number",
					"label": "ZIP Dauer an (s)",
					"sm": 12,
					"md": 4,
					"disabled": "data.regelung_aktiv === false"
				},
				"zip_last_run_min": {
					"type": "number",
					"label": "ZIP Dauer aus (s)",
					"sm": 12,
					"md": 4,
					"disabled": "data.regelung_aktiv === false"
				},
				"zip_aktiv_ww": {
					"type": "number",
					"label": "ZIP Dauer bei Warmwassererzeugung (s)",
					"sm": 12,
					"md": 4,
					"disabled": "data.regelung_aktiv === false"
				}
			}
		},
		"notifications": {
			"type": "panel",
			"label": "Benachrichtigungen",
			"icon": "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'%3E%3Cpath fill='currentColor' d='M12 22c1.1 0 2-.9 2-2h-4c0 1.1.9 2 2 2zm6-6v-5c0-3.07-1.63-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.64 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2zm-2 1H8v-6c0-2.48 1.51-4.5 4-4.5s4 2.02 4 4.5v6z'/%3E%3C/svg%3E",
			"items": {
				"telegram_aktiv": {
					"type": "checkbox",
					"label": "Fehlermeldungen per Telegram senden",
					"sm": 12,
					"md": 6
				},
				"show_errors_in_iobroker": {
					"type": "checkbox",
					"label": "Fehler auch als ioBroker-Log (Warn) zeigen",
					"sm": 12,
					"md": 6
				},
				"telegram_instance": {
					"type": "instance",
					"adapter": "telegram",
					"label": "Telegram-Instanz",
					"sm": 12,
					"md": 6,
					"hidden": "data.telegram_aktiv === false"
				},
				"telegram_receiver": {
					"type": "text",
					"label": "Empfänger (Name / Chat-ID - Optional)",
					"help": "Leer lassen, um die Nachricht an alle bekannten Telegram-Benutzer zu senden.",
					"sm": 12,
					"md": 6,
					"hidden": "data.telegram_aktiv === false"
				},
				"test_button": {
					"type": "sendTo",
					"label": "Test: Letzten Fehler senden",
					"command": "sendTestError",
					"data": {},
					"color": "secondary",
					"variant": "contained",
					"icon": "send",
					"sm": 12,
					"md": 4,
					"hidden": "data.telegram_aktiv === false"
				}
			}
		},
		"motionSensorsTab": {
			"type": "panel",
			"label": "Bewegungssensoren",
			"icon": "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'%3E%3Cpath fill='currentColor' d='M13.5 5.5c1.1 0 2-.9 2-2s-.9-2-2-2s-2 .9-2 2s.9 2 2 2zM9.8 8.9L7 23h2.1l1.8-8l2.1 2v6h2v-7.5l-2.1-2l.6-3C14.8 12 16.8 13 19 13v-2c-1.9 0-3.5-1-4.3-2.4l-1-1.6c-.4-.6-1-1-1.7-1c-.3 0-.5.1-.8.1L6 8.3V13h2V9.6l1.8-.7z'/%3E%3C/svg%3E",
			"items": {
				"motion_sensors_aktiv": {
					"type": "checkbox",
					"label": "Bewegungssensoren aktiv nutzen",
					"sm": 12
				},
				"headerSensors": {
					"type": "header",
					"text": "Bewegungssensoren für Zirkulationspumpe (ZIP)",
					"size": 4,
					"sm": 12
				},
				"motionSensors": {
					"type": "table",
					"sm": 12,
					"items": [
						{
							"type": "text",
							"attr": "name",
							"title": "Bezeichnung (z.B. Bad)",
							"width": "30%"
						},
						{
							"type": "objectId",
							"attr": "oid",
							"title": "Objekt-ID auswählen",
							"width": "70%"
						}
					]
				}
			}
		}
	}
}
